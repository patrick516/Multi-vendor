// backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  VENDOR
  CUSTOMER
}

enum CommissionStatus {
  PENDING
  PAID
}

enum CartLeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  COMPLETED
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     Role   @default(CUSTOMER)

  subscriptionActive Boolean @default(true)

  lastPaymentDate    DateTime?
  nextPaymentDue     DateTime?
  subscriptionAmount Float     @default(1000)
  mustPay            Boolean   @default(true)

  //  ADD THIS LINE
  mustChangePassword Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products          Product[]          @relation("VendorProducts")
  orders            Order[]            @relation("CustomerOrders")
  vendorCommissions VendorCommission[]

  cartLeads            CartLead[]
  subscriptionPayments SubscriptionPayment[]
  messageRecipients    MessageRecipient[]
}

model SubscriptionSettings {
  id        Int      @id @default(autoincrement())
  amount    Float    @default(1000) // MK 1000 default
  updatedAt DateTime @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  basePrice         Float
  displayPrice      Float
  commissionPerUnit Float
  stock             Int      @default(0)
  imageUrl          String?
  galleryImageUrls  String[] @default([])
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  district  String
  area      String?
  latitude  Float?
  longitude Float?

  vendorId Int
  vendor   User @relation("VendorProducts", fields: [vendorId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems  OrderItem[]
  commissions VendorCommission[]
  cartLeads   CartLead[]
}

model Order {
  id         Int  @id @default(autoincrement())
  customerId Int
  customer   User @relation("CustomerOrders", fields: [customerId], references: [id])

  totalAmount   Float
  status        OrderStatus @default(PENDING)
  customerPhone String?
  customerNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int   @default(1)
  unitPrice Float
}

model VendorCommission {
  id       Int  @id @default(autoincrement())
  vendorId Int
  vendor   User @relation(fields: [vendorId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity        Int   @default(1)
  basePrice       Float // what vendor gets per unit
  displayPrice    Float // customer price peenum r unit
  commission      Float // admin share per unit
  totalCommission Float // quantity * commission

  status    CommissionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  paidAt    DateTime?
}

model CartLead {
  id            Int     @id @default(autoincrement())
  productId     Int
  vendorId      Int
  customerName  String
  customerEmail String?
  customerPhone String?
  userId        Int?
  user          User?   @relation(fields: [userId], references: [id])

  product Product @relation(fields: [productId], references: [id])

  quantity Int            @default(1)
  note     String?
  status   CartLeadStatus @default(NEW)

  type String @default("CONTACT")

  createdAt DateTime @default(now())
}

model SubscriptionPayment {
  id          Int      @id @default(autoincrement())
  vendorId    Int
  vendor      User     @relation(fields: [vendorId], references: [id])
  amount      Float
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())
}

enum MessageTargetType {
  SINGLE
  MULTI
  ALL
}

model MessageLog {
  id         Int               @id @default(autoincrement())
  subject    String?
  message    String
  targetType MessageTargetType @default(SINGLE)
  createdAt  DateTime          @default(now())

  recipients MessageRecipient[]
}

model MessageRecipient {
  id        Int @id @default(autoincrement())
  messageId Int
  vendorId  Int

  message MessageLog @relation(fields: [messageId], references: [id])
  vendor  User       @relation(fields: [vendorId], references: [id])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
